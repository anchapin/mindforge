# MindForge Environment Variables
# Copy to .env and fill in your values

# Required
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Fernet key for token encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FERNET_KEY=your_fernet_key_here

# Service discovery (override in compose.yaml for docker)
CHROMA_HOST=http://chroma:8000
TEMPORAL_HOST=temporal:7233
OLLAMA_BASE_URL=http://ollama:11434

# Optional overrides
LOG_LEVEL=INFO

# Temporal — proactive workflow engine (Phase 3, opt-in)
# Set to true after starting `docker compose --profile temporal up -d`.
ENABLE_TEMPORAL=false

# Composio Cloud — Phase 4 integration umbrella (opt-in)
# When false (the default), Phase 1-3 direct integrations are used
# (Gmail IMAP/SMTP, GitHub, Linear, Stripe). Enable to route through
# Composio's 864+ app catalogue. POC stub landed via #56; live dispatch
# wires up in #57 (OAuth migration).
ENABLE_COMPOSIO=false
COMPOSIO_API_KEY=
